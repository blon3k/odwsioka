# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Shopify store (without https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=

# API version — use a supported version from Shopify docs
SHOPIFY_API_VERSION=2025-01

# Admin API — create a custom app in Shopify Admin → Settings → Apps → Develop apps
# Scopes needed: read_products
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storefront API — same custom app → Configuration → Storefront API integration
# Scopes needed: unauthenticated_write_checkouts, unauthenticated_read_checkouts,
#                unauthenticated_read_product_listings (or unauthenticated_read_product_inventory)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Map local product IDs (from frontend/src/data/products.ts) to Shopify variant GIDs.
# Find variant IDs in Shopify Admin → Products → variant → URL ends with /variants/123456789
# Format: gid://shopify/ProductVariant/123456789
PRODUCT_VARIANT_MAP={"mleko":"gid://shopify/ProductVariant/111","ser":"gid://shopify/ProductVariant/222","miod":"gid://shopify/ProductVariant/333","mleko-3pak":"gid://shopify/ProductVariant/444","pakiet-startowy":"gid://shopify/ProductVariant/555"}

# Telegram bot — create via @BotFather, then send /start to the bot to subscribe
TELEGRAM_BOT_API=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Shopify webhook secret — Settings → Notifications → Webhooks → create "Order payment"
# Webhook URL: https://your-backend.example.com/api/webhooks/shopify/orders
SHOPIFY_WEBHOOK_SECRET=
